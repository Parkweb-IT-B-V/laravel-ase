{
  "name": "parkweb/ase-laravel",
  "description": "Laravel integration for All Seeing Eye.",
  "version": "0.1.1",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/contracts": "^10.0|^11.0|^12.0",
    "guzzlehttp/guzzle": "^7.0",
    "nyholm/psr7": "^1.8",
    "php-http/discovery": "^1.20",
    "parkweb/ase-php": "^0.1.1"
  },
  "autoload": {
    "psr-4": {
      "ParkWeb\\Ase\\Laravel\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "ParkWeb\\Ase\\Laravel\\AseServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable"
